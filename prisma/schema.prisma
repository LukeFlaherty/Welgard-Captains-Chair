generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  name               String?
  email              String     @unique
  password           String
  role               String     @default("admin") // admin | team_member | vendor
  mustChangePassword Boolean    @default(false)
  inspectorId        String?
  inspector          Inspector? @relation("UserInspector", fields: [inspectorId], references: [id], onDelete: SetNull)
  vendorId           String?
  vendor             Vendor?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

// ─── Lightweight anchor entities ──────────────────────────────────────────────

model Inspector {
  id              String       @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  licenseNumber   String?
  licenseStates   String[]
  certifications  String[]
  yearsExperience Int?
  status          String       @default("active") // active | inactive | suspended
  notes           String?
  vendorId        String?
  vendor          Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  inspections     Inspection[]
  users           User[]       @relation("UserInspector")
}

model Member {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  serviceAddress String?
  ghlContactId   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  inspections    Inspection[]
}

model Vendor {
  id                  String       @id @default(cuid())
  companyName         String
  vendorType          String?      // Contractor | Inspector | Water Treatment | Real Estate Agent | Admin | Other
  primaryContact      String?
  email               String?
  phone               String?
  phone2              String?
  phone3              String?
  streetAddress       String?
  streetAddress2      String?
  city                String?
  county              String?
  state               String?
  zip                 String?
  taxId               String?
  licenseNumber       String?
  rating              String?      // 1 | 2 | 3 | Prospect
  notes               String?
  availableAfterHours Boolean      @default(false)
  availabilityNotes   String?
  startDate           DateTime?
  websiteUrl          String?
  ghlReferenceId      String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  inspections         Inspection[]
  inspectors          Inspector[]
  serviceTickets      ServiceTicket[]
  users               User[]
}

// ─── Primary entity ───────────────────────────────────────────────────────────

model Inspection {
  id String @id @default(cuid())

  // Relations
  memberId    String?
  vendorId    String?
  inspectorId String?
  member      Member?    @relation(fields: [memberId], references: [id])
  vendor      Vendor?    @relation(fields: [vendorId], references: [id])
  inspector   Inspector? @relation(fields: [inspectorId], references: [id])

  // Member & Property
  homeownerName    String
  homeownerEmail   String?
  homeownerEmail2  String?
  homeownerPhone   String?
  propertyAddress  String
  propertyAddress2 String?
  city             String?
  county           String?
  state            String?
  zip              String?

  // Realtor
  realtorInvolved     Boolean @default(false)
  requestedByRealtor  Boolean @default(false)
  realtorName         String?
  realtorEmail        String?
  realtorPhone        String?
  realtorPhoneType    String?

  // Inspection Source
  inspectorName     String?
  inspectionCompany String?
  inspectionDate    DateTime

  // Well System — basic info
  wellType         String?  // drilled | bored | hand_dug | stick | artesian | driven_point | other
  wellDepthFt      Float?
  wellDepthUnknown Boolean  @default(false)
  pumpType         String?  // submersible | jet | constant_pressure | hand | other
  pumpManufacturer String?  // unknown | franklin | goulds | grundfos | other
  pumpHp           String?  // 0_5hp | 0_75hp | 1hp | 1_5hp | 2hp | unknown | other

  // External Equipment inputs
  wellCompletionDate        String?
  wellCompletionDateUnknown Boolean @default(false)
  wellPermit                String?
  wellPermitUnknown         Boolean @default(false)
  wellDataSource            String?  // homeowner | official | notation_near_well | other
  wellObstructions          String?  // none | ornamental | buried | vegetation | debris | structural | other
  wellCap                   String?  // sealed_contamination_resistant | bored_well | not_applicable_buried | secured_bolted | unsecured_open | missing_damaged
  casingHeightInches        Float?
  casingType                String?  // pvc | steel | other
  casingSize                String?  // lt_4in | 4in | 6in | unknown | other
  distanceFromHouseFt       Float?

  // Internal Equipment inputs
  amperageReading        Float?
  tankCondition          String?  // good | fair | poor | failed
  tankBrand              String?  // state | welxtrol | other
  tankModel              String?
  tankSizeGal            Float?
  psiSettings            String?  // 30_50 | 40_60 | other
  controlBoxCondition    String?  // ok | not_present | damaged
  waterTreatment         String?  // softener | sediment_filter | other
  wireType               String?  // 12 | 10 | 8 | 2_wire | 3_wire | other
  pressureSwitch         String?  // visibly_present_intact | not_present | damaged
  pressureGauge          String?  // visibly_present_intact | not_present | damaged
  constantPressureSystem Boolean  @default(false)

  // Yield test method
  yieldTestType          String?  // flow_test | static_level_test

  // Cycle Test inputs
  secondsToHighReading Float?
  secondsToLowReading  Float?

  // Computed / stored values (recalculated on every save)
  cycleTime            Float?
  wellYieldGpm         Float?
  totalGallons         Float?
  avgMinutesToReach350 Float?
  gallonsPerDay        Int?

  // Category approval statuses
  externalEquipmentStatus String?  // pass | needs_attention
  internalEquipmentStatus String?  // pass | needs_attention
  cycleTimeStatus         String?  // pass | needs_attention
  wellYieldStatus         String?  // pass | needs_attention

  // Eligibility & tier
  wellCalculationVersion Int      @default(2)
  eligibleForSuperior    Boolean?
  membershipTier         String?  // standard | superior | premium

  // Notes & Findings
  inspectorNotes        String?
  internalReviewerNotes String?
  requiredRepairs       String?
  recommendedRepairs    String?
  memberFacingSummary   String?

  // Review & Status
  activity        String?
  systemStatus    String   @default("green")  // auto-computed tier color
  finalStatus     String   @default("green")  // may be manually overridden
  overrideReason  String?
  statusRationale String[]

  // GHL integration
  ghlContactId     String?
  ghlOpportunityId String?
  ghlLocationId    String?
  ghlSyncStatus    String   @default("pending")
  lastSyncedAt     DateTime?

  // PDF / Report
  reportId          String?
  generatedPdfUrl   String?
  reportGeneratedAt DateTime?

  // Meta
  isDraft   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Child relations
  yieldTests YieldTest[]
  photos     InspectionPhoto[]
  pdfHistory PdfGeneration[]
}

// Ordered yield test measurements (up to 6 per inspection)
model YieldTest {
  id                  String     @id @default(cuid())
  inspectionId        String
  inspection          Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  testNumber          Int        // 1–6
  startTime           String?    // "HH:MM" format (same-day test, time math only)
  totalGallons        Float?
  secondsToFillBucket Float?
  staticWaterLevelFt  Float?
  createdAt           DateTime   @default(now())

  @@unique([inspectionId, testNumber])
}

model PdfGeneration {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  url          String
  generatedAt  DateTime   @default(now())
}

model InspectionPhoto {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  url          String
  label        String?
  fileName     String?
  createdAt    DateTime   @default(now())
}

// ─── Service Tickets ──────────────────────────────────────────────────────────

model ServiceTicket {
  id           String  @id @default(cuid())
  ticketNumber Int     @unique

  // Member (fully inline — no FK)
  memberFirstName    String
  memberLastName     String
  memberEmail        String?
  memberAltEmail     String?
  memberPhone        String?
  memberPhoneType    String?
  memberAltPhone     String?
  memberAltPhoneType String?

  // Address (searchable)
  streetAddress  String
  streetAddress2 String?
  city           String?
  county         String?
  state          String?
  zip            String?

  // Core
  serviceType String  // general_maintenance | emergency
  status      String  @default("open") // open | scheduled | in_progress | completed

  // Dates
  callReceivedAt  DateTime
  scheduledFor    DateTime?
  lastServiceDate DateTime?

  // Service partner (one vendor per ticket)
  vendorId           String?
  vendor             Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  serviceCompletedBy String?  // free-text company name for import / fallback

  // Initial inquiry (team/admin fills at intake)
  callInNumber        String?
  customerInquiry     String?
  customerFollowUp    String?
  specialInstructions String?

  // Pre-service diagnostic checklist
  rightOfFirstRefusal Boolean?
  valvesOpen          String?  // yes | no | dont_know
  filterClogged       String?  // yes | no | dont_know
  circuitBreakerReset String?  // yes | no | dont_know
  lowPressureSwitch   String?  // yes | no | dont_know
  backwashCycle       String?  // yes | no | dont_know
  pressureGauge       Boolean?

  // Technician response (team/admin fills post-service)
  technicianResponse String?
  amperageReading    Float?
  yieldValue         Float?
  depthPerCustomer   Float?

  // Invoice & pricing (admin/team only — not shown to vendors)
  invoiceNumber      String?
  invoiceAmount      Float?
  invoicePaymentType String?
  invoiceAttachment  String?  // Vercel Blob URL
  servicePrice       Float?

  // Completion
  isComplete        Boolean @default(false)
  completedBy       String? // who marked it complete
  ticketCompletedBy String? // from source system

  // GHL
  ghlContactId String?

  // Meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
