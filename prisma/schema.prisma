generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  name               String?
  email              String     @unique
  password           String
  role               String     @default("admin") // admin | team_member | vendor
  mustChangePassword Boolean    @default(false)
  inspectorId        String?
  inspector          Inspector? @relation(fields: [inspectorId], references: [id], onDelete: SetNull)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

// ─── Lightweight anchor entities ──────────────────────────────────────────────

model Inspector {
  id              String       @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  licenseNumber   String?
  licenseStates   String[]
  certifications  String[]
  yearsExperience Int?
  status          String       @default("active") // active | inactive | suspended
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  inspections     Inspection[]
  users           User[]
}

model Member {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  serviceAddress String?
  ghlContactId   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  inspections    Inspection[]
}

model Vendor {
  id             String       @id @default(cuid())
  companyName    String
  inspectorName  String?
  email          String?
  phone          String?
  licenseNumber  String?
  ghlReferenceId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  inspections    Inspection[]
}

// ─── Primary entity ───────────────────────────────────────────────────────────

model Inspection {
  id String @id @default(cuid())

  // Relations
  memberId    String?
  vendorId    String?
  inspectorId String?
  member      Member?    @relation(fields: [memberId], references: [id])
  vendor      Vendor?    @relation(fields: [vendorId], references: [id])
  inspector   Inspector? @relation(fields: [inspectorId], references: [id])

  // Member & Property
  homeownerName   String
  homeownerEmail  String?
  homeownerPhone  String?
  propertyAddress String
  city            String?
  state           String?
  zip             String?

  // Inspection Source
  inspectorName     String?
  inspectionCompany String?
  inspectionDate    DateTime

  // Well System — basic info
  wellType         String?  // drilled | bored | hand_dug | stick | artesian | driven_point | other
  wellDepthFt      Float?
  wellDepthUnknown Boolean  @default(false)
  pumpType         String?  // submersible | jet | hand | other

  // External Equipment inputs
  wellObstructions   String?  // none | ornamental | vegetation | debris | structural | other
  wellCap            String?  // sealed_contamination_resistant | bored_well | not_applicable_buried | secured_bolted | unsecured_open | missing_damaged
  casingHeightInches Float?

  // Internal Equipment inputs
  amperageReading        Float?
  tankCondition          String?  // good | fair | poor | failed
  controlBoxCondition    String?  // ok | not_present | damaged
  pressureSwitch         String?  // visibly_present_intact | not_present | damaged
  pressureGauge          String?  // visibly_present_intact | not_present | damaged
  constantPressureSystem Boolean  @default(false)

  // Cycle Test inputs
  secondsToHighReading Float?
  secondsToLowReading  Float?

  // Computed / stored values (recalculated on every save)
  cycleTime            Float?
  wellYieldGpm         Float?
  totalGallons         Float?
  avgMinutesToReach350 Float?
  gallonsPerDay        Int?

  // Category approval statuses
  externalEquipmentStatus String?  // pass | needs_attention
  internalEquipmentStatus String?  // pass | needs_attention
  cycleTimeStatus         String?  // pass | needs_attention
  wellYieldStatus         String?  // pass | needs_attention

  // Eligibility & tier
  wellCalculationVersion Int      @default(2)
  eligibleForSuperior    Boolean?
  membershipTier         String?  // standard | superior | premium

  // Notes & Findings
  inspectorNotes        String?
  internalReviewerNotes String?
  requiredRepairs       String?
  recommendedRepairs    String?
  memberFacingSummary   String?

  // Review & Status
  activity        String?
  systemStatus    String   @default("green")  // auto-computed tier color
  finalStatus     String   @default("green")  // may be manually overridden
  overrideReason  String?
  statusRationale String[]

  // GHL integration
  ghlContactId     String?
  ghlOpportunityId String?
  ghlLocationId    String?
  ghlSyncStatus    String   @default("pending")
  lastSyncedAt     DateTime?

  // PDF / Report
  reportId          String?
  generatedPdfUrl   String?
  reportGeneratedAt DateTime?

  // Meta
  isDraft   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Child relations
  yieldTests YieldTest[]
  photos     InspectionPhoto[]
  pdfHistory PdfGeneration[]
}

// Ordered yield test measurements (up to 6 per inspection)
model YieldTest {
  id                  String     @id @default(cuid())
  inspectionId        String
  inspection          Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  testNumber          Int        // 1–6
  startTime           String?    // "HH:MM" format (same-day test, time math only)
  totalGallons        Float?
  secondsToFillBucket Float?
  createdAt           DateTime   @default(now())

  @@unique([inspectionId, testNumber])
}

model PdfGeneration {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  url          String
  generatedAt  DateTime   @default(now())
}

model InspectionPhoto {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  url          String
  label        String?
  fileName     String?
  createdAt    DateTime   @default(now())
}
